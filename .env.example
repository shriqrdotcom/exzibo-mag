# ─────────────────────────────────────────────────────────────────────────────
# EXZIBO — Environment Variables Reference
# Copy and fill in real values. NEVER commit real values to GitHub.
# Add ALL of these to: Vercel Dashboard → Project → Settings → Environment Variables
# Tick the "Production" checkbox for every variable below.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (REQUIRED) ───────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Better Auth (REQUIRED) ────────────────────────────────────────────────────
# BETTER_AUTH_SECRET: random 32+ char string — openssl rand -base64 32
BETTER_AUTH_SECRET=your_32_char_random_secret_here

# BETTER_AUTH_BASE_URL: the primary domain that Google OAuth callback uses.
# This MUST match the "Authorized redirect URI" in Google Cloud Console:
#   https://superadmin.exzibo.online/api/auth/callback/google
BETTER_AUTH_BASE_URL=https://superadmin.exzibo.online

# BETTER_AUTH_TRUSTED_ORIGINS: comma-separated list of ALL origins allowed to
# make auth requests. Add every domain/subdomain/Vercel URL that hosts the app.
# Example: https://superadmin.exzibo.online,https://dashboard.exzibo.online,https://exzibo-xxx.vercel.app
BETTER_AUTH_TRUSTED_ORIGINS=https://superadmin.exzibo.online,https://dashboard.exzibo.online

# ── Google OAuth (REQUIRED) ───────────────────────────────────────────────────
# Found in: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# IMPORTANT: You must also add this to Google Console → Authorized redirect URIs:
#   https://superadmin.exzibo.online/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here

# ── Neon PostgreSQL (REQUIRED) ────────────────────────────────────────────────
# Better Auth uses this to store sessions, users, and accounts.
# Found in: Neon Dashboard → your project → Connection string
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Superadmin access (REQUIRED on superadmin.exzibo.online) ─────────────────
# Comma-separated list of Google account emails allowed on the superadmin panel.
# Must match EXACTLY what Google returns (lowercase, no quotes, no spaces).
SUPERADMIN_ALLOWED_EMAILS=your@gmail.com

# ── Upstash Redis (REQUIRED — rate limiting + duplicate prevention) ───────────
# Found in: Upstash Console → your Redis database → REST API
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# ── Mobile app (optional — only needed when Expo / React Native clients exist) ─
# Comma-separated list of custom-scheme origins for the Expo app.
# Example: MOBILE_APP_TRUSTED_ORIGINS=exzibo://,exp+exzibo://
MOBILE_APP_TRUSTED_ORIGINS=

# ── Development only (do NOT set in Vercel Production) ───────────────────────
# VITE_DISABLE_AUTH=true        ← bypasses all auth (dev shortcut only)
# VITE_PREVIEW_MODE=true        ← enables preview login form instead of Google OAuth
