# ─────────────────────────────────────────────────────────────────────────────
# EXZIBO — Environment Variables Reference
# Copy this file and fill in real values. NEVER commit real values to GitHub.
# Add these to: Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (REQUIRED on Vercel — add to ALL environments) ──────────────────
# Found in: Supabase Dashboard → Project → Settings → API

# Your Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=your_supabase_project_url_here

# Supabase public/anon key (safe for browser — used by the frontend)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key (SECRET — server-side only, never exposed to browser)
# Add this to Vercel ONLY IF you are running server.js (not a static/serverless deploy)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Preview Login Bypass (OPTIONAL — only needed if using preview mode) ───────
# These enable an email+password login form as an alternative to Google OAuth
# Leave blank/unset in production if you only use Google OAuth

PREVIEW_EMAIL=your_preview_email_here
PREVIEW_PASSWORD_HASH=your_bcrypt_hashed_password_here
PREVIEW_SECRET=your_hmac_secret_here

# ── Development only (do NOT set in Vercel) ───────────────────────────────────
# VITE_DISABLE_AUTH=true        ← bypasses all auth (dev shortcut only)
# VITE_PREVIEW_MODE=true        ← enables preview login form instead of Google OAuth
