{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "outDir": "./dist-ts",
    "rootDir": "."
  },
  "include": ["src/db/**/*.ts", "drizzle.config.ts"],
  "exclude": ["node_modules", "dist"]
}
