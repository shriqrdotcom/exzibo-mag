{
  "rewrites": [
    { "source": "/api/menu/categories/upsert",              "destination": "/api/menu?action=upsertCategory"                               },
    { "source": "/api/menu/categories/delete",              "destination": "/api/menu?action=deleteCategory"                               },
    { "source": "/api/menu/categories/:restaurantId",       "destination": "/api/menu?action=getCategories&restaurantId=:restaurantId"     },
    { "source": "/api/menu/items/upsert",                   "destination": "/api/menu?action=upsertItems"                                  },
    { "source": "/api/menu/items/:restaurantId/published",  "destination": "/api/menu?action=getPublishedItems&restaurantId=:restaurantId" },
    { "source": "/api/menu/items/:restaurantId",            "destination": "/api/menu?action=getItems&restaurantId=:restaurantId"          },
    { "source": "/api/menu/items",                          "destination": "/api/menu?action=createItem"                                   },
    { "source": "/api/menu/item-patch",                     "destination": "/api/menu?action=updateItem"                                   },
    { "source": "/api/menu/item-delete",                    "destination": "/api/menu?action=deleteItem"                                   },
    { "source": "/api/menu/upload-image",                   "destination": "/api/media?action=uploadMenuImage"                             },
    { "source": "/api/about/upload-image",                  "destination": "/api/media?action=uploadAboutImage"                            },
    { "source": "/api/about/save",                          "destination": "/api/content?action=saveAbout"                                 },
    { "source": "/api/about/:restaurantId",                 "destination": "/api/content?action=getAbout&restaurantId=:restaurantId"       },
    { "source": "/api/restaurant/upload-logo",              "destination": "/api/media?action=uploadLogoImage"                             },
    { "source": "/api/restaurant/upload-carousel",          "destination": "/api/media?action=uploadCarouselImage"                         },
    { "source": "/api/restaurant/update-social",            "destination": "/api/content?action=updateSocial"                             },
    { "source": "/api/restaurant/update-profile",           "destination": "/api/restaurants?action=updateProfile"                        },
    { "source": "/api/orders/update-status",                "destination": "/api/orders?action=updateStatus"                              },
    { "source": "/api/orders/auto-cleanup",                 "destination": "/api/orders?action=autoCleanup"                               },
    { "source": "/api/orders/:restaurantId",                "destination": "/api/orders?restaurantId=:restaurantId"                       },
    { "source": "/api/preview-login",                       "destination": "/api/system?action=previewLogin"                              },
    { "source": "/api/preview-verify",                      "destination": "/api/system?action=previewVerify"                             },
    { "source": "/api/restaurant-db/create",                "destination": "/api/system?action=createRestaurantDb"                        },
    { "source": "/api/restaurant-db/drop",                  "destination": "/api/system?action=dropRestaurantDb"                          },
    { "source": "/api/restaurant-db/list",                  "destination": "/api/system?action=listRestaurantDb"                          },
    { "source": "/api/auth/:path*",                         "destination": "/api/auth?_path=:path*"                                        },
    { "source": "/api/neon/restaurants",                    "destination": "/api/restaurants?action=list"                                  },
    { "source": "/api/neon/restaurant/create",              "destination": "/api/restaurants?action=create"                                },
    { "source": "/api/neon/restaurant/by-slug/:slug",       "destination": "/api/restaurants?action=bySlug&slug=:slug"                    },
    { "source": "/api/neon/restaurant/by-uid/:uid",         "destination": "/api/restaurants?action=byId&id=:uid"                         },
    { "source": "/api/neon/restaurant/:id",                 "destination": "/api/restaurants?action=neonRestaurant&id=:id"                },
    { "source": "/api/restaurant/:id",                      "destination": "/api/restaurants?action=byId&id=:id"                          },
    { "source": "/api/neon/restaurant-settings/shadow-upsert", "destination": "/api/settings?action=setRestaurantSettings"                },
    { "source": "/api/bookings/:id/status",                 "destination": "/api/bookings?action=updateStatus&id=:id"                     },
    { "source": "/api/bookings/:restaurantId",              "destination": "/api/bookings?restaurantId=:restaurantId"                     },
    { "source": "/api/team-members/shadow-upsert",          "destination": "/api/team?action=shadowUpsert"                                },
    { "source": "/api/team-members/shadow-delete",          "destination": "/api/team?action=shadowDelete"                                },
    { "source": "/api/team-members/:restaurantId",          "destination": "/api/team?restaurantId=:restaurantId"                         },
    { "source": "/api/(.*)",                                "destination": "/api/$1"                                                       },
    { "source": "/(.*)",                                    "destination": "/index.html"                                                   }
  ]
}
