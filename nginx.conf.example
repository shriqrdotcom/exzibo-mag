# ─────────────────────────────────────────────────────────────────────────────
# Exzibo — Nginx configuration example
# Domain: exzibo.online
#
# Serves the same built React SPA (dist/) for all three subdomains.
# The app detects window.location.hostname at runtime and loads the correct
# isolated route tree (SuperAdminApp / DashboardApp / MenuApp).
#
# Prerequisites:
#   1. Build the app:  npm run build
#   2. Point dist/ at your webroot (or adjust root below)
#   3. Obtain wildcard SSL cert:
#        certbot certonly --manual --preferred-challenges dns \
#          -d exzibo.online -d "*.exzibo.online"
#   4. Replace /path/to/dist and /path/to/ssl with your actual paths
#   5. Run:  nginx -t && systemctl reload nginx
# ─────────────────────────────────────────────────────────────────────────────

# ── Redirect bare HTTP → HTTPS ────────────────────────────────────────────────
server {
    listen 80;
    server_name exzibo.online *.exzibo.online;
    return 301 https://$host$request_uri;
}

# ── superadmin.exzibo.online ──────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    server_name superadmin.exzibo.online;

    ssl_certificate     /path/to/ssl/fullchain.pem;
    ssl_certificate_key /path/to/ssl/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    root /path/to/dist;
    index index.html;

    location / {
        try_files $uri /index.html;
    }

    # Cache hashed assets forever; never cache index.html
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
    location = /index.html {
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }
}

# ── dashboard.exzibo.online ───────────────────────────────────────────────────
